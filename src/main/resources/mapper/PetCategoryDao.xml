<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.PetCategoryDao">

    <select id="selectListView" parameterType="map" resultType="com.entity.PetCategoryEntity">
        SELECT  c.* FROM pet_category  c
        <where> 1=1
            <if test="params.ids != null">
                and c.id in
                <foreach item="item" index="index" collection="params.ids" open="(" separator="," close=")">
                #{item}
                </foreach>
            </if>
            <if test=" params.name != '' and params.name != null and params.name != 'null' ">
                and c.name like CONCAT('%',#{params.name},'%')
            </if>
            <if test="params.parentId != null and params.parentId != ''">
                and c.parent_id = #{params.parentId}
            </if>
            <if test="params.level != null and params.level != ''">
                and c.level = #{params.level}
            </if>
        </where>
        order by c.${params.sort} ${params.order}
    </select>

</mapper>
