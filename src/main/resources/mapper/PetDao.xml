<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.PetDao">

    <select id="selectListView" parameterType="map" resultType="com.entity.PetEntity">
        SELECT  p.* FROM pets  p
        <where> 1=1
            <if test="params.ids != null">
                and p.id in
                <foreach item="item" index="index" collection="params.ids" open="(" separator="," close=")">
                #{item}
                </foreach>
            </if>
            <if test=" params.name != '' and params.name != null and params.name != 'null' ">
                and p.name like CONCAT('%',#{params.name},'%')
            </if>
            <if test="params.categoryId != null and params.categoryId != ''">
                and p.category_id = #{params.categoryId}
            </if>
            <if test=" params.gender != '' and params.gender != null and params.gender != 'null' ">
                and p.gender = #{params.gender}
            </if>
            <if test=" params.breed != '' and params.breed != null and params.breed != 'null' ">
                and p.breed like CONCAT('%',#{params.breed},'%')
            </if>
            <if test="params.status != null and params.status != ''">
                and p.status = #{params.status}
            </if>
            <if test="params.priceStart != null">
                <![CDATA[  and p.price >= #{params.priceStart}   ]]>
            </if>
            <if test="params.priceEnd != null">
                <![CDATA[  and p.price <= #{params.priceEnd}   ]]>
            </if>
        </where>
        order by p.${params.sort} ${params.order}
    </select>

</mapper>
